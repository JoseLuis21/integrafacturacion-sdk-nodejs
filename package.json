{
  "name": "@integradte/sdk",
  "version": "0.2.1",
  "description": "SDK Node.js/TypeScript para la API de IntegraDTE con arquitectura hexagonal",
  "keywords": [
    "integradte",
    "dte",
    "sii",
    "sdk",
    "typescript",
    "nodejs"
  ],
  "homepage": "https://github.com/JoseLuis21/integradte-sdk-nodejs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoseLuis21/integradte-sdk-nodejs.git"
  },
  "bugs": {
    "url": "https://github.com/JoseLuis21/integradte-sdk-nodejs/issues"
  },
  "license": "MIT",
  "author": "Jose Luis",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.36.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
